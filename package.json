{
  "name": "formforge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "db:setup:local": "wrangler d1 migrations apply formforge-db --local",
    "db:migrate:local": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "setup": "node setup.js"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "drizzle-orm": "0.38.3",
    "next": "15.1.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250408.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.0",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "drizzle-kit": "0.30.1",
    "typescript": "5.7.2"
  },
  "description": "Privacy-first open-source form backend for static sites on Cloudflare Workers and D1",
  "cloudflare": {
    "env-variables": [
      "APP_NAME",
      "RESEND_FROM"
    ],
    "secrets": [
      "AUTH_SECRET",
      "RESEND_API_KEY"
    ]
  }
}
